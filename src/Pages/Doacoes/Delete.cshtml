@page "{id:int}"
@model DoacoesDeleteModel
@{
    ViewData["Title"] = "Excluir Doação";
}

<h1>Excluir Doação</h1>
<div>
    <h4>Tem certeza que deseja excluir esta doação?</h4>
    <dl class="row">
        <dt class = "col-sm-2">Medicamento</dt>
        <dd class = "col-sm-10">@Model.Doacao.DoacaoNomeMedicamento</dd>
        <dt class = "col-sm-2">Validade</dt>
        <dd class = "col-sm-10">@Model.Doacao.DoacaoDataValidade.ToShortDateString()</dd>
        <dt class = "col-sm-2">Quantidade</dt>
        <dd class = "col-sm-10">@Model.Doacao.DoacaoQuantidadeMedicamento</dd>
    </dl>
    <form method="post">
        <button type="submit" class="btn btn-danger">Excluir</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
