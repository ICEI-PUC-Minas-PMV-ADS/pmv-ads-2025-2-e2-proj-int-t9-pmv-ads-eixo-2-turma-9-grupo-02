@model MedShare.Models.Doacao

@{
    ViewData["Title"] = "Doar - MedShare";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#2956a3" />
    <title>Doar - MedShare</title>
    <link rel="stylesheet" href="~/css/doacao/doar.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="main-container">
        <!-- Seção principal com formulário -->
        <div class="left-section">
            <div class="logo-title">
                <div class="logo-placeholder">💊</div>
                <h1>MedShare</h1>
                <p class="subtitle">O compartilhamento é indicado em casos de suspeita de sobras</p>
            </div>
            
            <div class="doacao-form">
                <h2 class="form-title">DOAR</h2>
                
                <form asp-controller="Doacao" asp-action="Doar" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger validation-summary"></div>
                    
                    <div class="form-group">
                        <label for="NomeMedicamento" class="form-label">NOME DO MEDICAMENTO</label>
                        <input asp-for="NomeMedicamento" type="text" class="form-control" />
                        <span asp-validation-for="NomeMedicamento" class="text-danger validation-error"></span>
                    </div>
                    
                    <div class="form-group">
                        <label for="Validade" class="form-label">VALIDADE</label>
                        <input asp-for="Validade" type="date" class="form-control" />
                        <span asp-validation-for="Validade" class="text-danger validation-error"></span>
                    </div>
                    
                    <div class="form-group">
                        <label for="FormaFarmaceutica" class="form-label">FORMA FARMACÊUTICA</label>
                        <select asp-for="FormaFarmaceutica" class="form-control">
                            <option value="">Selecione...</option>
                            <option value="Comprimido">Comprimido</option>
                            <option value="Cápsula">Cápsula</option>
                            <option value="Xarope">Xarope</option>
                            <option value="Pomada">Pomada</option>
                            <option value="Injetável">Injetável</option>
                            <option value="Gotas">Gotas</option>
                            <option value="Spray">Spray</option>
                            <option value="Outro">Outro</option>
                        </select>
                        <span asp-validation-for="FormaFarmaceutica" class="text-danger validation-error"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group quantidade-group">
                            <label for="Quantidade" class="form-label">QUANTIDADE</label>
                            <input asp-for="Quantidade" type="number" class="form-control quantidade-input" min="1" />
                            <span asp-validation-for="Quantidade" class="text-danger validation-error"></span>
                        </div>
                        
                        <div class="form-group imagem-group">
                            <label class="form-label">IMAGEM</label>
                            <div class="imagem-upload">
                                <input type="file" id="imagemUpload" name="ImagemFile" accept="image/*" class="file-input" />
                                <label for="imagemUpload" class="file-label">
                                    <span class="upload-icon">📷</span>
                                    <span class="upload-text">Adicionar Imagem</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="Descricao" class="form-label">DESCRIÇÃO/COMENTÁRIO</label>
                        <textarea asp-for="Descricao" class="form-control textarea-field" rows="4"></textarea>
                        <span asp-validation-for="Descricao" class="text-danger validation-error"></span>
                    </div>
                    
                    <div class="form-actions">
                        <button type="submit" class="salvar-btn">SALVAR</button>
                    </div>
                </form>
            </div>
        </div>
        
        <!-- Menu lateral direito -->
        <div class="right-section">
            <div class="menu-lateral">
                <div class="menu-header">
                    <div class="home-icon">🏠</div>
                </div>
                
                <div class="menu-items">
                    <a href="/Doacao/Doar" class="menu-item active">
                        <span class="menu-text">DOAR</span>
                    </a>
                    <a href="/Doacao/BuscarInstituicoes" class="menu-item">
                        <span class="menu-text">BUSCAR INSTITUIÇÕES</span>
                    </a>
                    <a href="/Doacao/MinhasDoacoes" class="menu-item">
                        <span class="menu-text">MINHAS DOAÇÕES</span>
                    </a>
                </div>
                
                <div class="user-menu">
                    <div class="user-icon">👤</div>
                    <div class="user-options">
                        <a href="/Admin/Notificacoes" class="user-option">
                            <span class="option-label">NOTIFICAÇÃO</span>
                        </a>
                        <a href="/Admin/Chat" class="user-option">
                            <span class="option-label">CHAT</span>
                        </a>
                        <a href="/Admin/Relatorio" class="user-option">
                            <span class="option-label">RELATÓRIO</span>
                        </a>
                        <a href="/Admin/EditarPerfil" class="user-option">
                            <span class="option-label">EDITAR PERFIL</span>
                        </a>
                        <a href="/Auth/Logout" class="user-option">
                            <span class="option-label">SAIR</span>
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Elemento circular azul decorativo -->
            <div class="decorative-circle"></div>
        </div>
    </div>
    
    <footer>
        <div class="footer-gradient"></div>
        <div class="footer-content">
            <div class="footer-info">
                <span>📍 Av. Dom José Gaspar, 500 Coração Eucarístico – Belo Horizonte – MG 30535-901, Brasil</span><br />
                <span>📞 Telefone: (31) 3319-4444</span><br />
                <span>📧 E-mail: contato@medshare.com</span>
            </div>
            <div class="footer-about">
                <span class="about-icon">ℹ️</span>
                <span>SOBRE NÓS</span>
            </div>
        </div>
    </footer>

    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }
</body>
</html>